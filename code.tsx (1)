'use client'
import { useEffect, useState } from 'react'
import { motion, useInView, useAnimation } from 'framer-motion'
import { ArrowRight, Users, DollarSign, CheckCircle, Clock } from 'lucide-react'
import Link from 'next/link'

const stats = [
  { name: 'المستخدمين المسجلين', value: 124567, suffix: '+' },
  { name: 'الأرباح المدفوعة', value: 2456789, suffix: '$' },
  { name: 'المهام المنجزة', value: 1567890, suffix: '+' },
  { name: 'متصلين الآن', value: 2345, suffix: '' }
]

export default function Home() {
  const [countedStats, setCountedStats] = useState({})

  const animateCounters = () => {
    stats.forEach(stat => {
      const duration = 2000
      const start = 0
      const end = stat.value
      const increment = end / (duration / 16)
      let current = 0
      const timer = setInterval(() => {
        current += increment
        if (current >= end) {
          current = end
          clearInterval(timer)
        }
        setCountedStats(prev => ({
          ...prev,
          [stat.name]: Math.floor(current)
        }))
      }, 16)
    })
  }

  useEffect(() => {
    const timer = setTimeout(animateCounters, 500)
    return () => clearTimeout(timer)
  }, [])

  const plans = [
    { id: 1, name: 'Starter', price: 50, duration: 1, tasks: 5, daily: 10 },
    { id: 2, name: 'Basic', price: 120, duration: 7, tasks: 10, daily: 25 },
    { id: 3, name: 'Silver', price: 300, duration: 15, tasks: 15, daily: 60 },
    { id: 4, name: 'Gold', price: 700, duration: 30, tasks: 20, daily: 120 },
    { id: 5, name: 'Platinum', price: 1500, duration: 90, tasks: 25, daily: 300 },
    { id: 6, name: 'Diamond', price: 3000, duration: 180, tasks: 30, daily: 650 },
    { id: 7, name: 'Ultimate', price: 7000, duration: 370, tasks: 40, daily: 1500 }
  ]

  return (
    <div className="min-h-screen">
      {/* Hero Section */}
      <section className="relative overflow-hidden pt-20 pb-32">
        <div className="absolute inset-0 bg-gradient-to-r from-purple-900/30 via-pink-900/20 to-blue-900/30" />
        <div className="container mx-auto px-4 relative z-10">
          <motion.div
            initial={{ opacity: 0, y: 50 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8 }}
            className="text-center"
          >
            <h1 className="text-5xl md:text-7xl font-bold mb-6 gradient-text leading-tight">
              ابدأ كسب المال
              <br />
              <span className="text-white">عبر تنفيذ المهام البسيطة</span>
            </h1>
            <p className="text-xl md:text-2xl mb-12 text-gray-300 max-w-2xl mx-auto leading-relaxed">
              انضم إلى آلاف المستخدمين الذين يكسبون أرباحًا يومية من خلال مهام بسيطة وممتعة
            </p>
            <div className="flex flex-col sm:flex-row gap-6 justify-center items-center">
              <Link href="/register">
                <button className="btn-primary flex items-center gap-3">
                  ابدأ الكسب الآن
                  <ArrowRight size={20} />
                </button>
              </Link>
              <Link href="#plans">
                <button className="btn-secondary flex items-center gap-3">
                  عرض الخطط
                  <ArrowRight size={20} />
                </button>
              </Link>
            </div>
          </motion.div>
        </div>
      </section>

      {/* Stats Section */}
      <section className="py-24 relative">
        <div className="container mx-auto px-4">
          <div className="grid grid-cols-2 md:grid-cols-4 gap-8">
            {stats.map((stat, index) => (
              <motion.div
                key={stat.name}
                initial={{ opacity: 0, scale: 0.8 }}
                animate={{ opacity: 1, scale: 1 }}
                transition={{ duration: 0.6, delay: index * 0.1 }}
                className="text-center glass p-8 rounded-3xl"
              >
                <div className="text-4xl md:text-5xl font-bold gradient-text mb-4">
                  {countedStats[stat.name] || 0}{stat.suffix}
                </div>
                <div className="text-gray-400 text-sm">{stat.name}</div>
              </motion.div>
            ))}
          </div>
        </div>
      </section>

      {/* How it Works */}
      <section className="py-24 bg-white/5">
        <div className="container mx-auto px-4">
          <motion.h2
            initial={{ opacity: 0, y: 30 }}
            whileInView={{ opacity: 1, y: 0 }}
            className="text-4xl md:text-5xl font-bold text-center mb-20 gradient-text"
          >
            كيفية العمل
          </motion.h2>
          <div className="grid md:grid-cols-4 gap-8">
            {[
              { icon: Users, title: 'إنشاء حساب', desc: 'سجل حسابك مجانًا في ثوان' },
              { icon: DollarSign, title: 'شراء اشتراك', desc: 'اختر الخطة المناسبة لك' },
              { icon: CheckCircle, title: 'تنفيذ المهام', desc: 'أكمل المهام اليومية' },
              { icon: Clock, title: 'سحب الأرباح', desc: 'اربح وسحب أرباحك فورًا' }
            ].map((step, index) => (
              <motion.div
                key={step.title}
                initial={{ opacity: 0, x: -50 }}
                whileInView={{ opacity: 1, x: 0 }}
                transition={{ duration: 0.6, delay: index * 0.1 }}
                className="card-hover text-center group"
              >
                <step.icon className="w-16 h-16 mx-auto mb-6 text-purple-400 group-hover:scale-110 transition-transform" />
                <h3 className="text-2xl font-bold mb-4">{step.title}</h3>
                <p className="text-gray-400">{step.desc}</p>
              </motion.div>
            ))}
          </div>
        </div>
      </section>

      {/* Plans Section */}
      <section id="plans" className="py-24">
        <div className="container mx-auto px-4">
          <motion.h2
            initial={{ opacity: 0, y: 30 }}
            whileInView={{ opacity: 1, y: 0 }}
            className="text-4xl md:text-5xl font-bold text-center mb-20 gradient-text"
          >
            خطط الاشتراك
          </motion.h2>
          <div className="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
            {plans.map((plan, index) => (
              <motion.div
                key={plan.id}
                initial={{ opacity: 0, y: 50 }}
                whileInView={{ opacity: 1, y: 0 }}
                transition={{ duration: 0.6, delay: index * 0.1 }}
                className="card-hover max-w-sm mx-auto"
              >
                <div className="text-center mb-8">
                  <h3 className="text-3xl font-bold text-white mb-2">{plan.name}</h3>
                  <div className="text-4xl font-bold gradient-text mb-2">${plan.price}</div>
                  <div className="text-gray-400">{plan.duration} يوم</div>
                </div>
                <div className="space-y-4 mb-8">
                  <div className="flex items-center gap-3">
                    <div className="w-2 h-2 bg-green-400 rounded-full" />
                    <span>{plan.tasks} مهام يومية</span>
                  </div>
                  <div className="flex items-center gap-3">
                    <div className="w-2 h-2 bg-green-400 rounded-full" />
                    <span>${plan.daily} ربح يومي</span>
                  </div>
                </div>
                <Link href="/register">
                  <button className="w-full btn-primary">
                    اشترك الآن
                  </button>
                </Link>
              </motion.div>
            ))}
          </div>
        </div>
      </section>
    </div>
  )
}
